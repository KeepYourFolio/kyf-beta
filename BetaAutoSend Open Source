const BETA2_SHEET = 'BetaCodes 2';
const NOTIF_EMAIL = 'VOTRE_EMAIL@gmail.com';
const KYF_SITE    = 'VOTRE_URL_KYF';
const KYF_X       = 'VOTRE_URL_X';

// ================================================================
// TRIGGER
// ================================================================
function onFormSubmit(e) {
  try {
    const responses = e.namedValues;

    // Recherche par inclusion partielle (évite les problèmes de \n\n)
    const wantsBetaEntry = Object.entries(responses).find(([k]) => k.includes('acc\u00e8s B\u00eata'));
    const emailEntry     = Object.entries(responses).find(([k]) => k.includes("code d'acc\u00e8s"));

    const wantsBetaVal = wantsBetaEntry ? wantsBetaEntry[1][0].trim().toLowerCase() : '';
    const betaEmail    = emailEntry     ? emailEntry[1][0].trim()                   : '';

    Logger.log('wantsBeta: ' + wantsBetaVal);
    Logger.log('betaEmail: ' + betaEmail);

    if (wantsBetaVal !== 'oui') { Logger.log('Pas oui — stop'); return; }
    if (!betaEmail || !betaEmail.includes('@')) { Logger.log('Pas d\'email — stop'); return; }

    const ss    = SpreadsheetApp.openById('VOTRE_SPREADSHEET_ID');
    const sheet = ss.getSheetByName(BETA2_SHEET);
    if (!sheet) { Logger.log('BetaCodes 2 introuvable'); return; }

    const data = sheet.getDataRange().getValues();
    let codeRow = -1, code = '';
    for (let i = 1; i < data.length; i++) {
      if (!(data[i][1] || '').toString().trim()) {
        codeRow = i + 1;
        code    = (data[i][0] || '').toString().replace(/[^\x20-\x7E]/g, '').trim();
        break;
      }
    }

    if (!code) {
      // Notifier admin
      GmailApp.sendEmail(NOTIF_EMAIL, '[KYF] Plus de codes Beta 2', 'Liste d\'attente : ' + betaEmail);
      // Mail liste d'attente à l'utilisateur
      GmailApp.sendEmail(betaEmail, '[KYF] Vous êtes sur liste d\'attente', '', {
        htmlBody: buildWaitingEmail(betaEmail),
        name: 'Keep Your Folio',
        replyTo: NOTIF_EMAIL
      });
      return;
    }

    const date = Utilities.formatDate(new Date(), 'Europe/Paris', 'yyyy-MM-dd HH:mm');
    sheet.getRange(codeRow, 2).setValue('RÉSERVÉ');
    sheet.getRange(codeRow, 3).setValue(date);
    sheet.getRange(codeRow, 4).setValue(betaEmail);

    const htmlBody = buildWelcomeEmail(code, betaEmail);
    GmailApp.sendEmail(betaEmail, '[KYF Beta 2] Votre code d\'accès', '', {
      htmlBody: htmlBody,
      name:     'Keep Your Folio',
      replyTo:  NOTIF_EMAIL
    });

    GmailApp.sendEmail(NOTIF_EMAIL,
      '[KYF Beta 2] Code envoyé : ' + code,
      'Code : ' + code + '\nEmail : ' + betaEmail + '\nDate : ' + date
    );

    // Masquer l'email après envoi (RGPD)
    const masked = betaEmail.replace(/(.{2})(.*)(@.*)/, '$1***$3');
    sheet.getRange(codeRow, 4).setValue(masked);

    Logger.log('Code ' + code + ' envoyé à ' + betaEmail);

  } catch (err) {
    Logger.log('Erreur : ' + err);
    GmailApp.sendEmail(NOTIF_EMAIL, '[KYF] Erreur envoi code', err.toString());
  }
}

