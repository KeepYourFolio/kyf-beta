// ================================================================
// INSTALLATION — Exécuter UNE FOIS depuis le Sheets réponses
// ================================================================
function installTrigger() {
  ScriptApp.getProjectTriggers().forEach(t => {
    if (t.getHandlerFunction() === 'onFormSubmit') ScriptApp.deleteTrigger(t);
  });
  // Écoute le Sheets actif (Sheets de réponses du Form)
  const ss = SpreadsheetApp.getActiveSpreadsheet();
  ScriptApp.newTrigger('onFormSubmit')
    .forSpreadsheet(ss)
    .onFormSubmit()
    .create();
  Logger.log('Trigger installé sur : ' + ss.getName());
}

function testAccess() {
  const ss = SpreadsheetApp.openById('VOTRE_SPREADSHEET_ID');
